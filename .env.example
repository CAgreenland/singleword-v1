# Copy to .env (never commit .env). Used by: npm run build → supabase-config.js

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional Fase 2 — base URL of the Node API (no trailing slash). Example local: http://127.0.0.1:3847
# SINGLEWORD_API_URL=http://127.0.0.1:3847
