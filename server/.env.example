# Copy to .env and adjust.

PORT=3847

# Required for POST /api/dev/entitlement (set paid/free while testing — no Lemon Squeezy needed).
# Use a long random string. Example PowerShell: [guid]::NewGuid().ToString('N')
DEV_API_KEY=change_me_to_a_long_random_secret

# Optional: allow GET /api/entitlement?email=… without a key, only from this computer (localhost).
# Handy for quick browser tests. Do not enable on a public server.
ALLOW_LOCAL_ENTITLEMENT_READ=1

# Later — Lemon Squeezy webhook signing secret (leave empty until you use real checkout)
# LEMONSQUEEZY_WEBHOOK_SECRET=
